rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isUserOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    function workspaceUserId(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.userId;
    }

    function isWorkspaceOwner(workspaceId) {
      return isSignedIn() && (workspaceUserId(workspaceId) == request.auth.uid || isAdmin());
    }

    function isPublishedWorkspaceForm(workspaceId, formId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/forms/$(formId)).data.status == 'published';
    }

    match /users/{userId} {
      allow read, write: if isUserOwner(userId);
    }

    match /system_stats/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /requests/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pricing/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /topups/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow write: if isAdmin();
    }

    match /promos/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notebooks/{notebookId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /reference_chunks/{chunkId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /public_forms/{slug} {
      allow read: if resource.data.status == 'published';
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /workspaces/{workspaceId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      match /references/{referenceId} {
        allow read, write: if isWorkspaceOwner(workspaceId);
      }

      match /forms/{formId} {
        allow read, write: if isWorkspaceOwner(workspaceId);

        match /responses/{responseId} {
          allow read, update, delete: if isWorkspaceOwner(workspaceId);
          allow create: if isWorkspaceOwner(workspaceId)
            || (
              request.auth == null
              && isPublishedWorkspaceForm(workspaceId, formId)
              && request.resource.data.workspaceId == workspaceId
              && request.resource.data.formId == formId
              && request.resource.data.submittedFrom == 'public-form'
            );
        }
      }

      match /transcripts/{transcriptId} {
        allow read, write: if isWorkspaceOwner(workspaceId);
      }

      match /analysisSnapshots/{snapshotId} {
        allow read, write: if isWorkspaceOwner(workspaceId);
      }

      match /notes/{noteId} {
        allow read, write: if isWorkspaceOwner(workspaceId);
      }
    }
  }
}
