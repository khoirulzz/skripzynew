{
  "name": "skripzy-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "next dev --turbo --hostname 0.0.0.0",
    "dev:landing": "npm run dev -w skripzy-landing -- -p 3000 --turbo",
    "dev:app": "npm run dev -w skripzy-dashboard -- -p 3001 --turbo",
    "build": "next build",
    "build:landing": "npm run build -w skripzy-landing",
    "build:app": "npm run build -w skripzy-dashboard",
    "start": "next start",
    "lint": "eslint"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "16.2.4"
  },
  "dependencies": {
    "@tiptap/extension-bubble-menu": "^3.22.3",
    "@tiptap/extension-color": "^3.22.5",
    "@tiptap/extension-highlight": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-subscript": "^3.22.5",
    "@tiptap/extension-superscript": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "firebase": "^12.12.0",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "next-pwa": "^5.6.0",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4"
  }
}